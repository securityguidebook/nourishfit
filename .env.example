VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI provider: "anthropic" (production) or "ollama" (local dev/free testing)
VITE_AI_PROVIDER=ollama

# Anthropic — only needed when VITE_AI_PROVIDER=anthropic
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Ollama — only needed when VITE_AI_PROVIDER=ollama
# Run locally: ollama serve && ollama pull qwen2.5 && ollama pull llava
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_CHAT_MODEL=qwen2.5
VITE_OLLAMA_VISION_MODEL=llava
